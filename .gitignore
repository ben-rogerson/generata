node_modules/
dist/
*.tgz
.DS_Store
.env
.env.local

# Tooling caches
.turbo/
.eslintcache

# Planning / brainstorming artefacts - kept local, not committed
docs/superpowers/

# Self-improve runtime artefacts - regenerated each workflow run
internal/self-improve/metrics/
internal/self-improve/logs/
internal/self-improve/last-run.md
internal/self-improve/last-diff.patch
internal/self-improve/IMPROVEMENTS.md

# Idea capture - local only, written by the /idea skill
internal/ideas/

# Default location for git worktrees created by `isolation: "worktree"` workflows.
# The default worktreeDir is a sibling of the repo and won't appear here, but a
# misconfigured worktreeDir pointing inside the repo would - keep ignored as
# defence in depth.
generata-worktrees/

# Marker for the user-level rtk-rewrite hook to skip this project
.no-rtk-rewrite
