{
  "name": "generata-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Composable multi-agent pipelines on top of the Claude Code CLI.",
  "author": "Ben Rogerson <info@benrogerson.dev>",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter '@generata/core' --filter '@generata/serve' build",
    "test": "pnpm -r --filter '@generata/core' --filter '@generata/serve' run test",
    "typecheck": "pnpm -r --filter './packages/core' --filter './packages/serve' --filter './internal/self-improve' typecheck",
    "lint": "pnpm -r --filter './packages/core' --filter './packages/serve' --filter './internal/self-improve' lint",
    "lint:fix": "pnpm -r --filter './packages/core' --filter './packages/serve' --filter './internal/self-improve' lint:fix",
    "fmt": "pnpm -r --filter './packages/core' --filter './packages/serve' --filter './internal/self-improve' fmt",
    "fmt:check": "pnpm -r --filter './packages/core' --filter './packages/serve' --filter './internal/self-improve' fmt:check",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "self-improve:audit": "pnpm --filter @generata/self-improve run audit",
    "self-improve:improve": "pnpm --filter @generata/self-improve run improve"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@generata/core": "workspace:*",
    "@types/node": "^25.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
